{{ header }}{{ column_left }}
<div id="content">
	<div class="page-header">
		<div class="container-fluid">
			<div class="pull-right">
				<button type="button" id="button-save-stickers" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary">
					<i class="fa fa-save"></i>
					Save Stickers
				</button>
				<a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default">
					<i class="fa fa-reply"></i>
				</a>
			</div>
			<h1>{{ heading_title }}</h1>
			<ul class="breadcrumb">
				{% for breadcrumb in breadcrumbs %}
					<li>
						<a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a>
					</li>
				{% endfor %}
			</ul>
		</div>
	</div>
	<div class="container-fluid">
		{% if error_warning %}
			<div class="alert alert-danger alert-dismissible">
				<i class="fa fa-exclamation-circle"></i>
				{{ error_warning }}
				<button type="button" class="close" data-dismiss="alert">&​times;</button>
			</div>
		{% endif %}

		<!-- Търсачка -->
		<div class="well">
			<div class="row">
				<div class="col-sm-4">
					<div class="form-group">
						<label class="control-label" for="input-filter-name">{{ entry_name }}</label>
						<input type="text" name="filter_name" value="{{ filter_name }}" placeholder="{{ entry_name }}" id="input-filter-name" class="form-control"/>
					</div>
					<button type="button" id="button-filter" class="btn btn-primary pull-right">
						<i class="fa fa-search"></i>
						{{ button_filter }}
					</button>
				</div>
			</div>
		</div>

		<div class="panel panel-default">
			<div class="panel-heading">
				<h3 class="panel-title">
					<i class="fa fa-pencil"></i>
					{{ text_edit }}</h3>
			</div>
			<div class="panel-body">
				<form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-advanced_category_stickers" class="form-horizontal">
					<div class="form-group">
						<label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
						<div class="col-sm-10">
							<select name="module_advanced_category_stickers_status" id="input-status" class="form-control">
								{% if module_advanced_category_stickers_status %}
									<option value="1" selected="selected">{{ text_enabled }}</option>
									<option value="0">{{ text_disabled }}</option>
								{% else %}
									<option value="1">{{ text_enabled }}</option>
									<option value="0" selected="selected">{{ text_disabled }}</option>
								{% endif %}
							</select>
						</div>
					</div>
				</form>
			</div>
			<div class="panel panel-default">
				<div class="panel-heading">
					<h3 class="panel-title">
						<i class="fa fa-list"></i>
						Category Stickers</h3>
				</div>
				<div class="panel-body">
					<form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-category-stickers">
						<div class="table-responsive">
							<table class="table table-bordered table-hover">
								<thead>
									<tr>
										<td class="text-left">Category Name</td>
										<td class="text-left">Sticker Text</td>
									</tr>
								</thead>
								<tbody>
									{% for category in categories %}
										<tr>
											<td class="text-left">{{ category.name }}</td>
											<td class="text-left">
												<input type="text" name="category_stickers[{{ category.category_id }}]" value="{{ category.sticker }}" class="form-control" placeholder="Enter sticker text">
											</td>
										</tr>
									{% endfor %}
								</tbody>
							</table>
						</div>
						<div class="row">
							<div class="col-sm-6 text-left">{{ pagination }}</div>
							<div class="col-sm-6 text-right">{{ results }}</div>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>

<script type="text/javascript">
$('#button-filter').on('click', function () {
  var url = 'index.php?route=extension/module/advanced_category_stickers&user_token={{ user_token }}';
  var filter_name = $('input[name="filter_name"]').val();

  if (filter_name) {
    url += '&filter_name=' + encodeURIComponent(filter_name);
  }

  location = url;
});

$('#button-save-stickers').on('click', function (e) {
  e.preventDefault();

  // Combine data from both forms
  var formData = $('#form-advanced_category_stickers').serialize() + '&' + $('#form-category-stickers input[type="text"]').serialize();

  $.ajax({
    url: 'index.php?route=extension/module/advanced_category_stickers/save&user_token={{ user_token }}',
    type: 'post',
    dataType: 'json',
    data: formData,
    beforeSend: function () {
      $('#button-save-stickers').button('loading');
      $('.alert-danger, .alert-success').remove();
    },
    complete: function () {
      $('#button-save-stickers').button('reset');
    },
    success: function (json) {
      if (json['error']) {
        $('#form-category-stickers').before(
          '<div class="alert alert-danger alert-dismissible">' +
          '<i class="fa fa-exclamation-circle"></i> ' + json['error'] + 
          '<button type="button" class="close" data-dismiss="alert">&times;</button>' +
          '</div>'
        );
      }

      if (json['success']) {
        $('#form-category-stickers').before(
          '<div class="alert alert-success alert-dismissible">' +
          '<i class="fa fa-check-circle"></i> ' + json['success'] + 
          '<button type="button" class="close" data-dismiss="alert">&times;</button>' +
          '</div>'
        );

        // Auto-hide success message after 3 seconds
        setTimeout(function () {
          $('.alert-success').fadeOut();
        }, 3000);
      }
    },
    error: function (xhr, ajaxOptions, thrownError) {
      alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
    }
  });
});

// Enter key support
$('#input-filter-name').on('keypress', function (e) {
  if (e.which === 13) {
    $('#button-filter').trigger('click');
    return false;
  }
});</script>

{{ footer }}
