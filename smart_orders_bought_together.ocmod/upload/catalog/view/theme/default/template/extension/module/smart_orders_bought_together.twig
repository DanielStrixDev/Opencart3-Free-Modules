<section class="smart-orders-bought-together" role="region" aria-label="Recommended products">
    <header>
        <h3>{{ text_people_bought_too }}</h3>
    </header>
    <div class="product-list" role="list">
        {% for product in recommend_products %}
            <article class="product-item" role="listitem">
                <div class="product-image">
                    <a href="{{ product.link }}" aria-label="View {{ product.title }}">
                        <img src="{{ product.image }}" alt="{{ product.title }}" title="{{ product.title }}" loading="lazy">
                    </a>
                </div>
                <div class="product-info">
                    <h4 class="product-name">
                        <a href="{{ product.link }}">{{ product.title }}</a>
                    </h4>
                </div>
            </article>
        {% endfor %}
    </div>
</section>